    "def task_4_complex_filter(df):\n",
    "    # 1. Фільтруємо за часом (> 18:00) та потужністю (> 6 кВт)\n",
    "    # Оскільки Time у нас рядки, порівняння '18:00:00' працює коректно\n",
    "    filtered = df[(df['Time'] > '18:00:00') & (df['Global_active_power'] > 6)]\n",
    "    \n",
    "    # 2. Визначаємо, де група 2 є найбільшою серед усіх трьох\n",
    "    filtered = filtered[(filtered['Sub_metering_2'] > filtered['Sub_metering_1']) & \n",
    "                        (filtered['Sub_metering_2'] > filtered['Sub_metering_3'])]\n",
    "    \n",
    "    # 3. Розділяємо на дві половини та робимо вибірку (крок 3 та крок 4)\n",
    "    n = len(filtered)\n",
    "    half = n // 2\n",
    "    \n",
    "    first_half = filtered.iloc[:half:3]   # Кожен третій з першої половини\n",
    "    second_half = filtered.iloc[half::4]  # Кожен четвертий з другої половини\n",
    "    \n",
    "    return pd.concat([first_half, second_half])\n",
    "\n",
    "execution_time_4 = timeit.timeit(lambda: task_4_complex_filter(df), number=1)\n",
    "result_4 = task_4_complex_filter(df)\n",
    "\n",
    "print(f\"Результат фільтрації: {len(result_4)} записів\")\n",
    "print(f\"Час виконання: {execution_time_4:.6f} секунд\")\n",
    "result_4.head()"
   ]
  },
