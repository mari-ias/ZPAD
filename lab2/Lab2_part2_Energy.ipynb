    "def normalize_and_standardize(df):\n",
    "    # Вибираємо тільки числові колонки для обробки\n",
    "    numeric_cols = df.select_dtypes(include=[np.number]).columns\n",
    "    data = df[numeric_cols]\n",
    "    \n",
    "    # Нормалізація (Min-Max: від 0 до 1)\n",
    "    scaler_minmax = MinMaxScaler()\n",
    "    normalized_data = scaler_minmax.fit_transform(data)\n",
    "    \n",
    "    # Стандартизація (Standard: середнє 0, відхилення 1)\n",
    "    scaler_std = StandardScaler()\n",
    "    standardized_data = scaler_std.fit_transform(data)\n",
    "    \n",
    "    return normalized_data, standardized_data\n",
    "\n",
    "norm, std = normalize_and_standardize(df)\n",
    "print(\"Дані успішно пронормовані та стандартизовані.\")\n",
    "print(f\"Приклад стандартизованого рядка: {std[0]}\")"
   ]
  },
