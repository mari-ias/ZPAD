    "def task_2_filter(df):\n",
    "    return df[(df['Global_intensity'] >= 19) & \n",
    "              (df['Global_intensity'] <= 20) & \n",
    "              (df['Sub_metering_2'] > df['Sub_metering_3'])]\n",
    "\n",
    "execution_time_2 = timeit.timeit(lambda: task_2_filter(df), number=1)\n",
    "result_2 = task_2_filter(df)\n",
    "\n",
