    "def task_3_sample(df):\n",
    "    sample_df = df.sample(n=500000, replace=False)\n",
    "    # Рахуємо середнє для груп Sub_metering_1, 2 та 3\n",
    "    averages = sample_df[['Sub_metering_1', 'Sub_metering_2', 'Sub_metering_3']].mean()\n",
    "    return averages\n",
    "\n",
    "execution_time_3 = timeit.timeit(lambda: task_3_sample(df), number=1)\n",
    "averages = task_3_sample(df)\n",
    "\n",
    "print(f\"Середні величини споживання:\\n{averages}\")\n",
    "print(f\"Час виконання: {execution_time_3:.6f} секунд\")"
   ]
  },
