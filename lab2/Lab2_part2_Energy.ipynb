   "source": [
    "# Перетворюємо всі стовпчики зі споживанням на float\n",
    "cols_to_convert = ['Global_active_power', 'Global_reactive_power', 'Voltage', \n",
    "                   'Global_intensity', 'Sub_metering_1', 'Sub_metering_2', 'Sub_metering_3']\n",
    "\n",
    "for col in cols_to_convert:\n",
    "    df[col] = pd.to_numeric(df[col], errors='coerce')\n",
    "\n",
    "# Видаляємо NaN, які могли з'явитися при конвертації\n",
    "df = df.dropna()\n",
    "print(\"Всі дані перетворено у числовий формат. Тепер можна аналізувати!\")"
   ]
