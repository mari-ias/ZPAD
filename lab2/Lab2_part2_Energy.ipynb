    "# Імпортуємо необхідні інструменти\n",
    "from scipy.stats import pearsonr, spearmanr\n",
    "\n",
    "# 6. Підрахунок коефіцієнтів Пірсона та Спірмена\n",
    "# Візьмемо активну потужність та силу струму (вони мають бути сильно пов'язані)\n",

    "from scipy.stats import pearsonr, spearmanr\n",
    "\n",
    "# 6. Підрахунок коефіцієнтів Пірсона та Спірмена\n",
    "# Візьмемо активну потужність та силу струму \n",

    "p_corr, _ = pearsonr(df['Global_active_power'], df['Global_intensity'])\n",
    "s_corr, _ = spearmanr(df['Global_active_power'], df['Global_intensity'])\n",
    "\n",
    "print(f\"Коефіцієнт Пірсона: {p_corr:.4f}\")\n",
    "print(f\"Коефіцієнт Спірмена: {s_corr:.4f}\")\n",
    "\n",

    "# 7. One Hot Encoding\n",
    "# Створимо фейковий категоріальний атрибут для демонстрації (наприклад, тип дня)\n",
    "df_sample = df.head(100).copy() # Беремо частину для швидкості\n",
    "df_sample['Day_Type'] = np.where(df_sample['Sub_metering_3'] > 5, 'High_Energy', 'Low_Energy')\n",
    "\n",
    "# Власне One Hot Encoding\n",
    "ohe_result = pd.get_dummies(df_sample['Day_Type'], prefix='Day')\n",
    "print(\"\\nРезультат One Hot Encoding (перші 5 рядків):\")\n",
    "ohe_result.head()"
   ]

    "\n",
    "# 7. One Hot Encoding (дві колонки, float)\n",
    "df_sample = df.head(100).copy()\n",
    "\n",
    "df_sample['Day_Type'] = np.where(df_sample['Sub_metering_3'] > 5, 'High_Energy', 'Low_Energy')\n",
    "df_sample['Day_Type'] = pd.Categorical(df_sample['Day_Type'], categories=['High_Energy', 'Low_Energy'])\n",
    "\n",
    "ohe_result = pd.get_dummies(df_sample['Day_Type'], prefix='Day', dtype=float)\n",
    "\n",
    "df_sample = pd.concat([df_sample, ohe_result], axis=1)\n",
    "\n",
    "print(\"Результат One Hot Encoding додано до таблиці:\")\n",
    "df_sample.head()"
   ]
